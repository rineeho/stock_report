# LLM API Configuration
# Choose one provider: openai or anthropic
LLM_PROVIDER=openai

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# LLM Model (optional, defaults to gpt-4o-mini for OpenAI, claude-sonnet-4-5-20250929 for Anthropic)
LLM_MODEL=

# Pipeline Settings
LOG_LEVEL=INFO
DATA_DIR=data
